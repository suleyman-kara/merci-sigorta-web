    <!-- ═══════════════════════ INSURANCE ═══════════════════════ -->
    <section id="insurance" class="section-pad" aria-labelledby="insurance-h2">
        <div class="container">
            <div class="insurance-grid">

                <div class="insurance-image animate">
                    {% image t.images.insuranceSrc, t.images.insuranceAlt, "(max-width: 768px) 100vw, 560px" %}
                </div>

                <div class="animate" style="--delay:.15s">
                    <span class="section-label">{{ t.insurance.label }}</span>
                    <h2 id="insurance-h2">{{ t.insurance.title }}</h2>
                    <div class="divider"></div>
                    <p>{{ t.insurance.desc }}</p>
                    <div class="insurance-types">
                        {%- for type in t.insurance.types %}
                        <div class="ins-item"><span class="ins-dot"></span>{{ type }}</div>
                        {%- endfor %}
                    </div>
                    <div style="margin-top:2rem;">
                        <a href="tel:{{ site.phone }}" class="btn btn-teal" id="insurance-call-btn">
                            {{ t.insurance.cta }}
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </section>
