    <!-- ═══════════════════════ SERVICES ═══════════════════════ -->
    <section id="services" class="section-pad" aria-labelledby="services-h2">
        <div class="container">
            <div class="services-header animate">
                <span class="section-label">{{ t.services.label }}</span>
                <h2 id="services-h2">{{ t.services.title }}</h2>
                <div class="divider"></div>
            </div>

            <div class="services-grid">
                {%- for item in t.services.items %}
                <div class="service-card animate" style="--delay:{{ loop.index0 * 0.05 }}s">
                    <div class="service-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                            stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="{{ serviceIcons[loop.index0] }}" />
                        </svg>
                    </div>
                    <h3>{{ item.title }}</h3>
                    {% if item.subtitle %}<span class="service-subtitle">{{ item.subtitle }}</span>{% endif %}
                    <p>{{ item.desc }}</p>
                </div>
                {%- endfor %}
            </div>
        </div>
    </section>
