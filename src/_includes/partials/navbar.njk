    <!-- ═══════════════════════ NAVBAR ═══════════════════════ -->
    <header>
        <nav id="navbar" role="navigation" aria-label="Main navigation">
            <div class="nav-inner">

                <!-- Logo -->
                <a href="#hero" class="nav-logo" aria-label="{{ site.name }}">
                    {% logoImage "img/new_logo.webp", t.nav.logoAlt %}
                </a>

                <!-- Links -->
                <ul id="nav-menu">
                    <li><a href="#about">{{ t.nav.about }}</a></li>
                    <li><a href="#services">{{ t.nav.services }}</a></li>
                    <li><a href="#insurance">{{ t.nav.insurance }}</a></li>
                    <li><a href="#contact">{{ t.nav.contact }}</a></li>
                </ul>

                <!-- Language Dropdown -->
                <div class="nav-actions">
                    <div class="lang-dropdown">
                        <button class="lang-btn" aria-label="Switch Language" aria-haspopup="true">
                            <svg class="globe-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a15 15 0 0 0 3-9 15 15 0 0 0-3-9M12 21a15 15 0 0 1-3-9 15 15 0 0 1 3-9M3.75 9h16.5M3.75 15h16.5" />
                            </svg>
                            <span>{{ lang | upper }}</span>
                            <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                            </svg>
                        </button>
                        <div class="lang-menu">
                            <a href="/ru/" {% if lang == "ru" %}class="active"{% endif %}>RU</a>
                            <a href="/en/" {% if lang == "en" %}class="active"{% endif %}>EN</a>
                            <a href="/tr/" {% if lang == "tr" %}class="active"{% endif %}>TR</a>
                        </div>
                    </div>

                    <!-- Hamburger -->
                    <button id="hamburger" class="hamburger" aria-expanded="false" aria-controls="nav-menu"
                        aria-label="{{ t.nav.menuOpen }}">
                        <span></span><span></span><span></span>
                    </button>
                </div>

            </div>
        </nav>
        <div id="nav-overlay" aria-hidden="true"></div>
    </header>
