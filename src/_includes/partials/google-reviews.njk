<!-- ═══════════════════════ GOOGLE REVIEWS ═══════════════════════ -->
<section id="reviews" class="section-pad">
    <div class="container">
        
        <div class="reviews-header">
            <div class="reviews-header-top">
                <div class="google-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                </div>
                <h2>{{ t.reviews.title | default("Müşterilerimizin Gözünden") }}</h2>
            </div>
            
            {% if googleBusiness.rating > 0 %}
            <div class="reviews-stats">
                <span class="reviews-rating-num">{{ googleBusiness.rating }}</span>
                <div class="reviews-stars">
                    {% for i in range(0, 5) %}
                        <svg viewBox="0 0 24 24" fill="currentColor" class="star-icon">
                            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                        </svg>
                    {% endfor %}
                </div>
                <span class="reviews-count">({{ googleBusiness.userRatingCount }} {{ t.reviews.countText | default("Değerlendirme") }})</span>
            </div>
            {% if googleBusiness.lastUpdate %}
            <p style="font-size: 0.8rem; color: var(--text-soft); margin-top: -0.5rem; margin-bottom: 1rem;">{{ t.reviews.lastUpdated | default("Son Güncelleme") }}: {{ googleBusiness.lastUpdate }}</p>
            {% endif %}
            {% endif %}
            <div class="divider"></div>
        </div>

        {% if googleBusiness.reviews and googleBusiness.reviews.length > 0 %}
        <div class="reviews-grid">
            {% for review in googleBusiness.reviews %}
            <div class="review-card">
                <div class="review-author">
                    {% if review.authorPhoto %}
                    <img src="{{ review.authorPhoto }}" alt="{{ review.authorName }}" class="review-author-img" loading="lazy" width="40" height="40" referrerpolicy="no-referrer">
                    {% else %}
                    <div class="review-author-initial">{{ review.authorName.charAt(0) }}</div>
                    {% endif %}
                    <div class="review-author-info">
                        <strong>{{ review.authorName }}</strong>
                        <span>{{ review.relativeTime }}</span>
                    </div>
                </div>
                <div class="review-stars-small">
                    {% for i in range(0, review.rating) %}
                        ★
                    {% endfor %}
                </div>
                <p class="review-text">"{{ review.text }}"</p>
                <!-- Dili belli etmek için (opsiyonel) -->
                {% if review.language and review.language != "tr" %}
                 <span class="review-lang-badge">{{ review.language | upper }}</span>
                {% endif %}
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if googleBusiness.photos and googleBusiness.photos.length > 0 %}
        <div class="gallery-header">
            <h3>{{ t.reviews.galleryTitle | default("Ofisimizden Kareler") }}</h3>
            <div class="divider"></div>
        </div>
        
        <div class="gallery-grid">
            {% for photo in googleBusiness.photos %}
            <div class="gallery-item">
                <img src="{{ photo.url }}" alt="Merci Sigorta Office" loading="lazy" width="400" height="300" referrerpolicy="no-referrer">
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if googleBusiness.url %}
        <div style="text-align: center; margin-top: 3rem;">
            <a href="{{ googleBusiness.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline" style="border-color: var(--teal-deeper); color: var(--teal-deeper);">
                {{ t.reviews.viewOnGoogle | default("Google'da Görüntüle") }}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; height:16px; margin-left:4px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
            </a>
        </div>
        {% endif %}

    </div>
</section>
