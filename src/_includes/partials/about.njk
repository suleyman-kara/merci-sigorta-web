    <!-- ═══════════════════════ ABOUT ═══════════════════════ -->
    <section id="about" class="section-pad" aria-labelledby="about-h2">
        <div class="container">
            <div class="about-grid">

                <div class="about-text animate">
                    <span class="section-label">{{ t.about.label }}</span>
                    <h2 id="about-h2">{{ t.about.title }}</h2>
                    <div class="divider"></div>
                    <p>{{ t.about.p1 }}</p>
                    <p style="margin-top:1rem;">{{ t.about.p2 }}</p>
                </div>

                <div class="about-stats animate" style="--delay:.15s">
                    <div class="stat-block">
                        <div class="stat-num">{{ t.about.stat1Num }}</div>
                        <div class="stat-label">{{ t.about.stat1Label }}</div>
                    </div>
                    <div class="stat-block">
                        <div class="stat-num">{{ t.about.stat2Num }}</div>
                        <div class="stat-label">{{ t.about.stat2Label }}</div>
                    </div>
                    <div class="stat-block">
                        <div class="stat-num">{{ t.about.stat3Num }}</div>
                        <div class="stat-label">{{ t.about.stat3Label }}</div>
                    </div>
                    <div class="stat-block">
                        <div class="stat-num">{{ t.about.stat4Num }}</div>
                        <div class="stat-label">{{ t.about.stat4Label }}</div>
                    </div>
                </div>

            </div>
        </div>
    </section>
